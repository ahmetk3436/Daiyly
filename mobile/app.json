{
  "expo": {
    "name": "Daiyly",
    "slug": "daiyly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "daiyly",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#eff6ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daiyly.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Daiyly uses Face ID to protect your journal entries"
      }
    },
    "android": {
      "package": "com.daiyly.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#eff6ff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication"
    ]
  }
}
